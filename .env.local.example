# ── LiveKit ──────────────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── ElevenLabs ───────────────────────────────────────────────────────────────
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Used by: /api/chat (text chat), /api/summarize (session memory)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Used by: Railway agent (STT + LLM fallback) — not required on Vercel
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# ── fal.ai ───────────────────────────────────────────────────────────────────
# Used by: /api/create-avatar (full-body avatar generation via flux-pulid)
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key

# ── Stability AI ─────────────────────────────────────────────────────────────
# Used by: /api/stylize-avatar (face portrait stylization for Hedra)
# Get from: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_stability_api_key

# ── Hedra ────────────────────────────────────────────────────────────────────
# Used by: Railway agent only (talking-head lip-sync video)
# Get from: https://www.hedra.com/app/settings → API
HEDRA_API_KEY=your_hedra_api_key

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Auto-provisioned by Vercel — do not set manually
# BLOB_READ_WRITE_TOKEN=auto

# ── Neon (PostgreSQL) ─────────────────────────────────────────────────────────
# Auto-provisioned by Vercel/Neon — do not set manually
# DATABASE_URL=auto
